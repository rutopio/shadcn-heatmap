{
  "name": "shadcn-heatmap",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "description": "Beautiful, accessible heatmap components for React. Built with shadcn/ui conventions.",
  "author": "rutopio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rutopio/shadcn-heatmap.git"
  },
  "homepage": "https://shadcn-heatmap.pages.dev",
  "bugs": {
    "url": "https://github.com/rutopio/shadcn-heatmap/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:registry && tsc -b && vite build",
    "build:registry": "tsx scripts/build-registry.ts",
    "format": "prettier --write . && node scripts/format-snippets.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "check": "pnpm audit && pnpm format && pnpm lint && pnpm typecheck"
  },
  "dependencies": {
    "@phosphor-icons/react": "2.1.10",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tanstack/react-router": "1.168.23",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "2.13.0",
    "@eslint/js": "9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@shikijs/core": "3.23.0",
    "@shikijs/engine-oniguruma": "3.23.0",
    "@shikijs/langs": "3.23.0",
    "@shikijs/themes": "3.23.0",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/eslint-plugin-query": "5.96.2",
    "@tanstack/eslint-plugin-router": "1.161.6",
    "@tanstack/router-plugin": "1.167.22",
    "@types/node": "22.19.17",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.0.1",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "shiki": "3.23.0",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0",
    "vite": "6.4.2"
  }
}
